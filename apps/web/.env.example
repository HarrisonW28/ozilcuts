# Optional: absolute API origin (e.g. https://api.example.com). When unset in the
# browser, requests use same-origin `/api/...` (use a reverse proxy in production).
NEXT_PUBLIC_API_URL=

# Dev only: Laravel origin for Next.js `/api/*` rewrites in next.config.ts
BACKEND_URL=http://localhost:8000

# Optional: marketing homepage cinematic video (self-host under /public/marketing/ recommended)
# NEXT_PUBLIC_HOME_HERO_VIDEO_MP4=/marketing/hero.mp4
# NEXT_PUBLIC_HOME_HERO_VIDEO_WEBM=/marketing/hero.webm
# NEXT_PUBLIC_HOME_AMBIENT_VIDEO_MP4=/marketing/ambient.mp4
# NEXT_PUBLIC_HOME_AMBIENT_VIDEO_WEBM=/marketing/ambient.webm
# NEXT_PUBLIC_HOME_HERO_VIDEO_POSTER=/marketing/hero-poster.jpg

# Optional: social & Instagram link-out tiles (no embeds)
# NEXT_PUBLIC_INSTAGRAM_HANDLE=ozilcuts
# NEXT_PUBLIC_TIKTOK_HANDLE=
# NEXT_PUBLIC_SOCIAL_PROOF_FOLLOWERS=2.4k+
# NEXT_PUBLIC_SOCIAL_PROOF_POSTS=180+
# NEXT_PUBLIC_INSTAGRAM_HIGHLIGHTS_JSON=[{"id":"fades","label":"Fades","href":"https://www.instagram.com/ozilcuts/","imageUrl":"/marketing/ig-fades.jpg"}]
