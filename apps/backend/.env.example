APP_NAME=Ozilcuts
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the public URL of the Laravel API (include port in local dev, e.g. http://127.0.0.1:8000).
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# DB_URL=postgres://postgres:postgres@127.0.0.1:5432/ozilcuts?sslmode=disable
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ozilcuts
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=prefer

# Local databases via Docker (from apps/backend): docker compose up -d
# DB_PASSWORD=postgres

# Local fallback without PostgreSQL (absolute path recommended):
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SPA URL for OAuth return (fragment carries token + user payload)
FRONTEND_URL=http://localhost:3000

# Google OAuth — set redirect URI to ${APP_URL}/api/v1/auth/google/callback (include port in local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/google/callback"

# Stripe — leave STRIPE_SECRET empty to disable deposits site-wide.
# Use test keys (sk_test_..., pk_test_...) for local development.
STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

HORIZON_PATH=horizon
