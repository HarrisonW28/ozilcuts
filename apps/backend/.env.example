APP_NAME=Ozilcuts
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the public URL of the Laravel API (include port in local dev, e.g. http://127.0.0.1:8000).
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Sanctum personal access token lifetime (minutes). Default ~30 days.
SANCTUM_TOKEN_EXPIRATION_MINUTES=43200
# Per-IP auth attempt cap (login/register) per minute
SECURITY_AUTH_RATE_LIMIT=10
# Authenticated API baseline per user per minute
SECURITY_AUTHENTICATED_API_RATE_LIMIT=240
SECURITY_PUBLIC_API_RATE_LIMIT=120
SECURITY_FORCE_HTTPS=false
# Comma-separated SPA origins for CORS (defaults to FRONTEND_URL)
# CORS_ALLOWED_ORIGINS=https://app.example.com
SECURITY_TRUSTED_PROXIES=
SECURITY_UPLOAD_MAX_KB=5120
AUDIT_LOG_ENABLED=true
ABUSE_PROTECTION_ENABLED=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# DB_URL=postgres://postgres:postgres@127.0.0.1:5432/ozilcuts?sslmode=disable
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ozilcuts
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=prefer

# Local databases via Docker (from apps/backend): docker compose up -d
# DB_PASSWORD=postgres

# Local fallback without PostgreSQL (absolute path recommended):
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Uploads (logos, hero video) are stored on the API via POST /api/v1/admin/marketing/* — not on Vercel.
# Production: set APP_URL to your public API origin; use FILESYSTEM_DISK=s3 (or a persistent volume + public disk).
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SPA URL for OAuth return (fragment carries token + user payload)
FRONTEND_URL=http://localhost:3000

# Google OAuth — set redirect URI to ${APP_URL}/api/v1/auth/google/callback (include port in local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/google/callback"

# Stripe — leave STRIPE_SECRET empty to disable deposits site-wide.
# Use test keys (sk_test_..., pk_test_...) for local development.
STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gbp
# Tap / POS roadmap surfaced in public payment config: off | foundation | live
STRIPE_TAP_TO_PAY_STATUS=foundation

HORIZON_PATH=horizon

# Optional OpenAI for staff appointment summaries (see AppointmentCustomerAiSummaryService).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_SUMMARY_MODEL=gpt-4o-mini
